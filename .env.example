# Stripe configuration — copy this file to .env.local and fill in real values.
# Never commit real keys. .env.local is gitignored.

# Publishable key (safe to expose to the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Secret key (server-only — never expose to the client)
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret for /api/webhook signature verification
# Local dev: run `stripe listen --forward-to localhost:3000/api/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend — order confirmation emails (https://resend.com/api-keys)
RESEND_API_KEY=re_xxx
# Verified sender address. onboarding@resend.dev works for testing without a domain.
RESEND_FROM="Wellness Shop <onboarding@resend.dev>"
